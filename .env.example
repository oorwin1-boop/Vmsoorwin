# ==============================================
# ENVIRONMENT CONFIGURATION
# ==============================================

# Test Environment: development | staging | production
TEST_ENV=development

# ==============================================
# APPLICATION URLs
# ==============================================

BASE_URL=https://app.beanhiredev.com
API_BASE_URL=https://app.beanhiredev.com

# ==============================================
# TEST CREDENTIALS
# ==============================================

# Standard test user (recruiter role)
TEST_USER_EMAIL=pavant+ui@oorwin.com
TEST_USER_PASSWORD=Password123!

# Admin user
ADMIN_EMAIL=admin@oorwin.ai
ADMIN_PASSWORD=AdminPass123!

# Recruiter user
RECRUITER_EMAIL=recruiter@oorwin.ai
RECRUITER_PASSWORD=RecruiterPass123!

# Hiring Manager user
HIRING_MANAGER_EMAIL=hiringmanager@oorwin.ai
HIRING_MANAGER_PASSWORD=HMPass123!

# ==============================================
# BROWSER SETTINGS
# ==============================================

# Set to 'true' to run in headed mode locally
HEADED=false

# Slow down actions for visual debugging (milliseconds)
SLOW_MO=0

# ==============================================
# PARALLEL EXECUTION
# ==============================================

# Number of parallel workers (leave blank for auto)
WORKERS=4

# ==============================================
# LOGGING
# ==============================================

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ==============================================
# REPORTING
# ==============================================

ALLURE_RESULTS_DIR=allure-results
