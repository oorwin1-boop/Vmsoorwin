{
  "name": "oorwin-playwright-framework",
  "version": "1.0.0",
  "description": "Production-ready Playwright E2E Test Automation Framework for Oorwin AI",
  "author": "Oorwin AI QA Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:sanity": "playwright test --grep @sanity",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:dev": "cross-env TEST_ENV=development playwright test",
    "test:staging": "cross-env TEST_ENV=staging playwright test",
    "test:prod": "cross-env TEST_ENV=production playwright test",
    "report:show": "playwright show-report playwright-report",
    "report:allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "report:allure:open": "allure open ./allure-report",
    "report:allure:serve": "allure serve ./allure-results",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf playwright-report allure-results allure-report test-results playwright/.auth",
    "install:browsers": "playwright install --with-deps"
  },
  "keywords": [],
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "allure-playwright": "^3.9.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "winston": "^3.19.0"
  }
}
